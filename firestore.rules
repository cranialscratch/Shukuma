rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'matt@uservox.com';
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // Users — own doc: signed-in user can read/write their own; admin: full access to all
    match /users/{uid} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow write: if isSignedIn() && request.auth.uid == uid;
      allow read, write: if isAdmin();
    }

    // Scores — own docs only (id starts with uid), or admin
    match /scores/{scoreId} {
      allow read, write: if isSignedIn() && scoreId.matches(request.auth.uid + '_.*');
      allow read, write: if isAdmin();
    }

    // Config — all signed-in users can read; only admin can write
    match /config/{doc} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Feedback (bug reports) — any signed-in user can create; admin can read all
    match /feedback/{doc} {
      allow create: if isSignedIn();
      allow read, write: if isAdmin();
    }

    // Word lists — pre-certified word lists per puzzle; signed-in users can read, only admin can write
    match /wordlists/{puzzleId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
